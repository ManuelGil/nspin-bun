{
	"name": "nspin-bun",
	"version": "1.2.1",
	"description": "Fast and lightweight ESM spinner package optimized for Bun and modern Node.js runtimes",
	"keywords": [
		"bun",
		"cli",
		"console",
		"esm",
		"loader",
		"node",
		"spinner",
		"terminal",
		"tty",
		"typescript",
		"zero-dependencies",
		"lightweight"
	],
	"author": {
		"name": "Manuel Gil",
		"email": "support@imgil.dev",
		"url": "https://imgil.dev/"
	},
	"license": "MIT",
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/ManuelGil"
	},
	"homepage": "https://github.com/ManuelGil/nspin-bun",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ManuelGil/nspin-bun.git"
	},
	"bugs": {
		"url": "https://github.com/ManuelGil/nspin-bun/issues"
	},
	"type": "module",
	"packageManager": "bun@1.3.0",
	"engines": {
		"node": ">=22.19.0",
		"bun": ">=1.3.0"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"imports": {
		"#src/*": "./src/*"
	},
	"sideEffects": false,
	"files": [
		"dist",
		"README.md",
		"CHANGELOG.md",
		"LICENSE",
		"!dist/**/*.map"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"clean": "rm -rf dist",
		"build": "bun build src/index.ts --outdir=dist --minify --target=node && bun run build:types",
		"build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"ts-check": "tsc --noEmit",
		"check-exports": "attw --pack --ignore-rules cjs-resolves-to-esm",
		"audit": "bun audit",
		"audit:fix": "pnpm audit --fix",
		"deps:update": "bun update",
		"deps:update:latest": "bun update --latest",
		"pack:check": "bun pm pack",
		"prepare": "bunx husky",
		"release": "release-it",
		"prepublishOnly": "bun run validate && cp README.npm.md README.md",
		"postpublish": "git checkout -- README.md",
		"validate": "bun run check && bun run ts-check && bun test && bun run build && bun run check-exports"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "0.18.3",
		"@biomejs/biome": "2.5.0",
		"@commitlint/cli": "20.5.3",
		"@commitlint/config-conventional": "20.5.3",
		"@types/node": "22.19.21",
		"bun-types": "1.3.14",
		"globals": "16.5.0",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"release-it": "20.2.0",
		"typescript": "6.0.3"
	},
	"lint-staged": {
		"*.{ts,js,json,md}": [
			"biome check --write"
		]
	},
	"release-it": {
		"git": {
			"commitMessage": "chore: :bookmark: release ${version}",
			"tagName": "v${version}",
			"requireCleanWorkingDir": true
		},
		"github": {
			"release": true
		},
		"npm": {
			"publish": false
		},
		"hooks": {
			"before:init": "bun run validate",
			"before:release": "bun run build"
		}
	}
}
